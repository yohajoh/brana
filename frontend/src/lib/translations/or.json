  "faq": {
    "title": "Gaaffiiwwan Yeroo Baay'ee Gaafataman",
    "questions": [
      {
        "question": "Akkamittan kitaaba liqeeffachuu danda'a?",
        "answer": "Kaataaloogii keenya keessatti kitaaba barbaadaa, 'Borrow' kan jedhu cuqaasaa, qajeelfama hordofuun dormii keessanitti akka geeffamu gaafadhaa."
      },
      {
        "question": "Kitaaba yeroo hammamiitiif qabachuu danda'a?",
        "answer": "Kitaaba tokko torban 2f qabachuu dandeessu. Namni biraan yoo hin qabanne dheeressuu gaafachuu dandeessu."
      },
      {
        "question": "Kitaabni ani barbaadu yoo hin jirre hoo?",
        "answer": "Kitaaba kamiyyuu irratti tarree eeggataa irratti makamuu dandeessu. Akkuma deebi'ee fi qophii ta'een isiniif beeksisna."
      },
      {
        "question": "Sirni Kiraayii Kitaaba Birana Maali?",
        "answer": "Birana barattoonni gufuu mana kitaabaa aadaa malee beekumsa salphaatti akka argatan fi qooddatan kan qophaa'e, bakka jireenyaa kitaabota barnootaa fi hafuuraa ti."
      },
      {
        "question": "Waa'ee kitaaba kootii akkamittan beeksifama?",
        "answer": "Yeroo kitaabni keessan geessitiiaf qophii ta'u ykn deebiiaf yeroon geessetti appii keenya fi karaa quunnamtii galmeessitaniin beeksifamtu."
      },
      {
        "question": "Akkamittan kitaaba deebisa?",
        "answer": "Kitaabicha bakka sassaabbbii murteeffame irratti gatuu ykn appii kanaan dormii keessan irraa akka fuutamu gaafachuu dandeessu."
      }
    ]
  },
