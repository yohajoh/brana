  "faq": {
    "title": "Frequently Asked Questions",
    "questions": [
      {
        "question": "How do I borrow a book?",
        "answer": "Simply search for the book in our catalog, click 'Borrow', and follow the instructions to request delivery to your dorm."
      },
      {
        "question": "How long can I keep a book?",
        "answer": "You can typically keep a book for 2 weeks. You can request an extension if no one else has reserved it."
      },
      {
        "question": "What if the book I want is not available?",
        "answer": "You can join the waitlist for any book. We'll notify you as soon as it's returned and ready for you."
      },
      {
        "question": "What is Birana Book Rental System?",
        "answer": "Birana is a digital sanctuary for academic and spiritual books, designed specifically for students to easily access and share knowledge within their community without the traditional library hurdles."
      },
      {
        "question": "How will I be notified about my book?",
        "answer": "You'll receive notifications via our app and through your registered contact method when your book is ready for delivery or due for return."
      },
      {
        "question": "How do I return a book?",
        "answer": "You can drop off the book at designated collection points or request a pickup from your dorm through the app."
      }
    ]
  },
